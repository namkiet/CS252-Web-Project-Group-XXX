graph TD
    User["Browser (User)"]

    %% --- SERVER SIDE ---
    subgraph "Server (Flask App)"
        App["Flask App (app.py)"]

        %% --- Shared Resources (Global) ---
        subgraph "Shared Resources (Global)"
            DB[Database]
            Shared_Templates["Shared Templates (Global)"]
            Shared_Static["Shared Static (Global)"]
        end

        %% --- Blueprints (With private resources) ---
        subgraph "Blueprints"
            
            subgraph "User Blueprint"
                BP_Users["User Logic (routes)"]
                User_Templates["User Templates (Private)"]
                User_Static["User Static (Private)"]
            end

            subgraph "Food Blueprint"
                BP_Food["Food Logic (routes)"]
                Food_Templates["Food Templates (Private)"]
                Food_Static["Food Static (Private)"]
            end
        end

        subgraph AI["AI System"]
            AI_Data["Data"]
            AI_Logic["Ranking system"]
        end
        %% --- FLOWS & RELATIONSHIPS ---

        %% App registers Blueprints
        App -- "registers" --> BP_Users
        App -- "registers" --> BP_Food

        %% Blueprints use shared DB
        BP_Users -- "uses" --> DB
        BP_Food -- "uses" --> DB
        BP_Food -- "uses" --> AI

        %% Blueprints render from their private templates
        BP_Users -- "renders from" --> User_Templates
        BP_Food -- "renders from" --> Food_Templates

        %% Private templates FALLBACK to shared templates
        User_Templates -. "fallback" .-> Shared_Templates
        Food_Templates -. "fallback" .-> Shared_Templates

        %% Private static FALLBACK to shared static
        User_Static -. "fallback" .-> Shared_Static
        Food_Static -. "fallback" .-> Shared_Static
    end

    %% --- CLIENT-SERVER INTERACTION ---
    User -- "1. Send HTTP Request" --> App
    App -- "2. Send HTML (from Jinja)" --> User
    
    %% Flask automatically routes static requests
    User -- "3. Request Static Files (CSS/JS)" --> App
    App -- "4. Send Static Files" --> User